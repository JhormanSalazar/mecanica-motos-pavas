{
  "$schema": "https://railway.com/railway.schema.json",
  "services": {
    "backend": {
      "source": {
        "root": "backend"
      },
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "Dockerfile"
      },
      "deploy": {
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      },
      "variables": {
        "NODE_ENV": "production",
        "FRONTEND_URL": "${{frontend.RAILWAY_PUBLIC_DOMAIN_VALUE}}",
        "DATABASE_URL": "${{MySQL.DATABASE_URL}}",
        "JWT_SECRET": "",
        "PORT": "4000"
      }
    },
    "frontend": {
      "source": {
        "root": "frontend"
      },
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "Dockerfile",
        "buildArgs": {
          "REACT_APP_API_URL": "https://${{backend.RAILWAY_PUBLIC_DOMAIN}}/api"
        }
      },
      "deploy": {
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      }
    }
  }
}
