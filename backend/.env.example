# ============================================
# BACKEND — Variables de entorno (PLANTILLA)
# ============================================
# Copia este archivo como .env y completa los valores.

NODE_ENV=development
PORT=4000

# MySQL — Desarrollo (XAMPP): mysql://root:@localhost:3306/taller_mx
# MySQL — Producción (Railway): se provee automáticamente como DATABASE_URL
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"

# JWT — usa un string largo y aleatorio en producción
JWT_SECRET="CHANGE_ME_min_32_chars_long_random_string"

# CORS — URL del frontend permitido
# Desarrollo: http://localhost:3000
# Producción: https://tu-frontend.up.railway.app
FRONTEND_URL="http://localhost:3000"

# ============================================
# EMAIL — Configuración de correos (Brevo)
# ============================================
# Brevo/Sendinblue (GRATIS - 300 emails/día)
# 1. Crea cuenta en: https://app.brevo.com/
# 2. Ve a: https://app.brevo.com/settings/keys/api
# 3. Copia tu API key (empieza con xkeysib-)
BREVO_API_KEY="xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Email del remitente (puede ser cualquier email)
# NO requiere verificación de dominio para empezar
FROM_EMAIL="no-reply@tallermotos.com"
FROM_NAME="Taller SKM"

# Configuración opcional de reintentos y timeouts
EMAIL_RETRIES=2
EMAIL_SEND_TIMEOUT_MS=15000

# SMTP Alternativo (opcional, solo si no usas Brevo)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu-email@gmail.com
# SMTP_PASS=tu-password

# Cola de correos (opcional)
# EMAIL_USE_QUEUE=false
