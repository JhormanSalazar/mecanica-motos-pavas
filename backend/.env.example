# ============================================
# BACKEND — Variables de entorno (PLANTILLA)
# ============================================
# Copia este archivo como .env y completa los valores.

NODE_ENV=development
PORT=4000

# MySQL — Desarrollo (XAMPP): mysql://root:@localhost:3306/taller_mx
# MySQL — Producción (Railway): se provee automáticamente como DATABASE_URL
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"

# JWT — usa un string largo y aleatorio en producción
JWT_SECRET="CHANGE_ME_min_32_chars_long_random_string"

# CORS — orígenes permitidos (separados por coma)
CORS_ORIGIN="http://localhost:3000"
