generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  role     String // "ADMIN" | "MECHANIC"
}

model Pilot {
  id       Int       @id @default(autoincrement())
  name     String
  bikeType String
  phone    String?
  email    String?
  logs     WorkLog[]
}

model ChecklistItem {
  id        Int             @id @default(autoincrement())
  name      String
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  results   WorkLogResult[]
}

model WorkLog {
  id        Int             @id @default(autoincrement())
  hours     Float
  type      String          // "ALISTAMIENTO" | "REPARACION"
  createdAt DateTime        @default(now())
  pilotId   Int
  pilot     Pilot           @relation(fields: [pilotId], references: [id])
  results   WorkLogResult[] // Corregido: sin la 's' extra

  @@index([pilotId])
}

model WorkLogResult {
  id              Int           @id @default(autoincrement())
  workLogId       Int
  workLog         WorkLog       @relation(fields: [workLogId], references: [id], onDelete: Cascade)
  checklistItemId Int
  checklistItem   ChecklistItem @relation(fields: [checklistItemId], references: [id])
  name            String        
  status          String        
  obs             String?       @db.Text

  @@index([workLogId])
  @@index([checklistItemId])
}