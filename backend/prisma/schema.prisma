generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum WorkLogType {
  ALISTAMIENTO
  REPARACION
}

enum WorkLogResultStatus {
  SI
  NO
}

enum WorkLogState {
  PENDIENTE
  EN_PROCESO
  TERMINADO
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  role     String // "ADMIN" | "MECHANIC"

  @@map("users")
}

model Pilot {
  id       Int       @id @default(autoincrement())
  name     String
  bikeType String
  phone    String?
  email    String?
  logs     WorkLog[]

  @@map("pilots")
}

model ChecklistItem {
  id        Int             @id @default(autoincrement())
  name      String
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  results   WorkLogResult[]

  @@map("checklist_items")
}

model WorkLog {
  id        Int             @id @default(autoincrement())
  hours     Float
  type      WorkLogType     // "ALISTAMIENTO" | "REPARACION"
  state     WorkLogState    @default(PENDIENTE) // PENDIENTE | EN_PROCESO | TERMINADO
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  pilotId   Int
  pilot     Pilot           @relation(fields: [pilotId], references: [id])
  results   WorkLogResult[]

  @@index([pilotId])
  @@map("worklogs")
}

model WorkLogResult {
  id              Int           @id @default(autoincrement())
  workLogId       Int
  workLog         WorkLog       @relation(fields: [workLogId], references: [id], onDelete: Cascade)
  checklistItemId Int?
  checklistItem   ChecklistItem? @relation(fields: [checklistItemId], references: [id])
  name            String        
  status          WorkLogResultStatus?
  obs             String?       @db.Text
  isCustom        Boolean       @default(false)

  @@index([workLogId])
  @@index([checklistItemId])
  @@map("worklog_results")
}